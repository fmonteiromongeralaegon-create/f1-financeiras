# URL base da API em produção (Vercel).
# Em desenvolvimento no Replit, o proxy Vite encaminha /api/* automaticamente para localhost:8080.
# Em produção, defina esta variável no painel do Vercel (Settings → Environment Variables)
# apontando para a URL pública do servidor de API implantado.
VITE_API_BASE_URL=https://sua-api.replit.app
